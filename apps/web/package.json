{
  "name": "@prompteer/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "locales": "node ../../scripts/generate-web-locales.mjs",
    "dev": "../../scripts/web-dev.sh",
    "build": "pnpm run locales && ../../scripts/web-build.sh",
    "lint": "pnpm run locales && eslint .",
    "typecheck": "pnpm run locales && tsc --noEmit",
    "test": "pnpm run locales && vitest run --coverage --passWithNoTests",
    "test:coverage": "pnpm run locales && vitest run --coverage --passWithNoTests",
    "test:e2e": "pnpm run locales && playwright test"
  },
  "dependencies": {
    "@auth/core": "0.41.2",
    "@hookform/resolvers": "^5.4.0",
    "@prompteer/shared-types": "workspace:*",
    "@sentry/nextjs": "^10.54.0",
    "@tanstack/react-query": "^5.100.14",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.1.0",
    "openapi-fetch": "0.17.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@prompteer/eslint-config": "workspace:*",
    "@prompteer/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
