                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "level": {
            "$ref": "#/components/schemas/ChallengeLevel"
          },
          "tag": {
            "$ref": "#/components/schemas/ChallengeTag"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "challenge_number",
          "tag",
          "level",
          "title",
          "content"
        ],
        "title": "ChallengeRead",
        "type": "object"
      },
      "ChallengeRunRequest": {
        "properties": {
          "prompt": {
            "maxLength": 4000,
            "minLength": 10,
            "title": "Prompt",
            "type": "string"
