        "required": ["posts", "shares"],
        "title": "BoardFeedRead",
        "type": "object"
      },
      "ChallengeLevel": {
        "enum": ["easy", "medium", "hard"],
        "title": "ChallengeLevel",
        "type": "string"
      },
      "ChallengeRead": {
        "properties": {
          "challenge_number": {
            "title": "Challenge Number",
            "type": "integer"
