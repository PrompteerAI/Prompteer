# === Core ===
# Runtime environment. Use development locally; production enables stricter defaults.
ENV=development

# Public application URL used in OAuth callbacks and emails.
APP_URL=http://localhost:3000

# API base URL used by the web app in local development.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# === Database ===
# PostgreSQL connection string for the FastAPI app. Safe local Compose default.
DATABASE_URL=postgresql+psycopg://prompteer:prompteer@localhost:5432/prompteer

# Postgres container settings. Safe local Compose defaults.
POSTGRES_USER=prompteer
POSTGRES_PASSWORD=prompteer
POSTGRES_DB=prompteer

# === Cache and jobs ===
# Redis URL for cache, rate limiting, and Celery broker/result backend.
REDIS_URL=redis://localhost:6379/0

# === Development bootstrap ===
# Runs Alembic migrations and idempotent demo seed data when the API starts outside production.
AUTO_SEED_ON_STARTUP=true

# Number of times the API waits for the local database during development bootstrap.
DEV_BOOTSTRAP_RETRIES=30

# Delay in seconds between development bootstrap retries.
DEV_BOOTSTRAP_RETRY_SECONDS=1

# === Auth ===
# Auth.js secret. In production set a high-entropy value; local dev may use this value.
AUTH_SECRET=dev-auth-secret-change-in-production

# Auth.js URL. Must match APP_URL for local dev.
AUTH_URL=http://localhost:3000

# Local mock Google OIDC issuer used when GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET are blank.
AUTH_MOCK_GOOGLE_ISSUER=http://localhost:8000

# JWKS endpoint exposed by the web app for API-side Auth.js JWT validation.
AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks

# Issuer claim for Auth.js API JWTs. Must match AUTH_URL locally.
AUTH_JWT_ISSUER=http://localhost:3000

# Audience claim expected by the FastAPI backend.
AUTH_JWT_AUDIENCE=prompteer-api

# Optional RS256 private key PEM for Auth.js API JWTs. Empty generates a dev-only key at startup.
AUTH_JWT_PRIVATE_KEY=

# Key id exposed in the Auth.js JWKS document.
AUTH_JWT_KEY_ID=prompteer-dev-auth

# Google OAuth client id. Leave blank to use the mock Google OAuth provider.
GOOGLE_CLIENT_ID=

# Google OAuth client secret. Leave blank to use the mock Google OAuth provider.
GOOGLE_CLIENT_SECRET=

# Enables deterministic dev login routes and seed users. Defaults true in dev, false in prod.
AUTH_ALLOW_SEED_LOGIN=true

# Enables browser-visible Google auth mock affordances in local development.
NEXT_PUBLIC_USE_MOCK_GOOGLE=true

# === Observability ===
# Emit JSON logs when true. Defaults to false outside production.
LOG_JSON=false

# Optional Sentry DSN for backend errors. Empty disables Sentry.
SENTRY_DSN=

# Optional Sentry DSN for browser/server web errors. Empty disables Sentry.
NEXT_PUBLIC_SENTRY_DSN=

# === External APIs (leave blank to use mocks) ===
# OpenAI API key. Empty selects the deterministic mock LLM client unless Anthropic is set.
OPENAI_API_KEY=

# OpenAI API base URL. Defaults to the official v1 API; useful for tests or proxies.
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API key. Empty selects the deterministic mock LLM client unless OpenAI is set.
ANTHROPIC_API_KEY=

# Anthropic API base URL. Defaults to the official v1 API; useful for tests or proxies.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Anthropic API version header sent to the Messages API.
ANTHROPIC_VERSION=2023-06-01

# Stripe secret key. Empty selects the mock payments client.
STRIPE_SECRET_KEY=

# Stripe publishable key for browser checkout. Empty selects the mock payments UI.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret. Empty selects mock webhook signing.
STRIPE_WEBHOOK_SECRET=

# Twilio SendGrid API key. Empty selects the mock email client.
SENDGRID_API_KEY=

# Default sender used by real and mock email clients.
SENDGRID_FROM_EMAIL=no-reply@prompteer.dev

# === Feature flags ===
# Enables dev-only routes such as /api/v1/dev/mailbox and mock checkout completion.
ENABLE_DEV_ROUTES=true

# Enables LLM prompt runs and provider-compatible LLM mock endpoints.
FEATURE_LLM_ENABLED=true

# Enables billing checkout and provider-compatible Stripe mock endpoints.
FEATURE_PAYMENTS_ENABLED=true

# Enables email delivery and the provider-compatible SendGrid mock endpoint.
FEATURE_EMAIL_ENABLED=true
