# === Core ===
# Runtime environment. Use development locally; production enables stricter defaults.
ENV=development

# Application version attached to API logs and release metadata.
APP_VERSION=0.1.0

# Public application version attached to browser release metadata.
NEXT_PUBLIC_APP_VERSION=0.1.0

# Public application URL used in OAuth callbacks and emails.
APP_URL=http://localhost:3000

# Docker Compose nginx host port for the containerized app.
HTTP_PORT=80

# Local hot-reload web port used by pnpm dev.
WEB_PORT=3000

# Local hot-reload API port used by pnpm dev and make api-dev.
API_PORT=8000

# Gunicorn-managed Uvicorn worker processes in the API container.
# Defaults to 1; increase for single-host deployments after sizing CPU and DB pools.
API_UVICORN_WORKERS=1

# Safety ceiling for API_UVICORN_WORKERS. Raise only for intentionally large hosts.
API_UVICORN_WORKERS_MAX=32

# API base URL used by the browser and server-rendered web app pages.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Internal API base URL used by Next.js route handlers. Compose points this at the api service.
API_INTERNAL_URL=http://localhost:8000/api/v1

# === Database ===
# PostgreSQL connection string for the FastAPI app. Safe local Compose default.
DATABASE_URL=postgresql+psycopg://prompteer:prompteer@localhost:5432/prompteer

# Postgres container settings. Safe local Compose defaults.
POSTGRES_USER=prompteer
POSTGRES_PASSWORD=prompteer
POSTGRES_DB=prompteer

# Postgres host port published by Docker Compose for local tools.
POSTGRES_PORT=5432

# Optional output path for scripts/backup-db.sh. Empty writes ./backups/prompteer.dump.
BACKUP_FILE=

# Optional database URL override for scripts/backup-db.sh. Empty uses DATABASE_URL.
BACKUP_DATABASE_URL=

# Optional database URL override for scripts/restore-db.sh. Empty uses DATABASE_URL.
RESTORE_DATABASE_URL=

# Maintenance database URL for make backup-restore-check. Empty derives a local postgres DB URL.
MAINTENANCE_DATABASE_URL=

# Source database URL for make backup-restore-check. Empty uses a local throwaway database.
SOURCE_DATABASE_URL=

# Keep throwaway backup/restore verification databases after make backup-restore-check.
KEEP_BACKUP_RESTORE_DATABASES=false

# === Cache and jobs ===
# Redis URL for cache, rate limiting, and Celery broker/result backend.
REDIS_URL=redis://localhost:6379/0

# Redis host port published by Docker Compose for local tools and API tests.
REDIS_PORT=6379

# Enables API rate limiting. Disable only for one-off local debugging.
RATE_LIMIT_ENABLED=true

# Rate-limit storage backend. Local dev uses Redis so limits work across API workers.
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/0

# SlowAPI/limits strategy. moving-window avoids fixed-window boundary bursts.
RATE_LIMIT_STRATEGY=moving-window

# Prefix for keys written by the rate limiter storage backend.
RATE_LIMIT_KEY_PREFIX=prompteer

# Include X-RateLimit-* and Retry-After headers on limited responses.
RATE_LIMIT_HEADERS_ENABLED=true

# General authenticated and public CRUD route rate limit.
GENERAL_RATE_LIMIT=60/minute

# LLM prompt-run rate limits for cost-sensitive routes.
LLM_RATE_LIMIT=10/minute;200/hour

# Daily LLM token cap for free users. Admin users are uncapped.
LLM_FREE_DAILY_TOKEN_CAP=50000

# Daily LLM token cap for paid users. Admin users are uncapped.
LLM_PAID_DAILY_TOKEN_CAP=500000

# Billing and mock Stripe route rate limit.
PAYMENTS_RATE_LIMIT=5/minute

# SendGrid-compatible email route rate limit.
EMAIL_RATE_LIMIT=5/minute;20/day

# === Development bootstrap ===
# Runs Alembic migrations and idempotent demo seed data when the API starts outside production.
AUTO_SEED_ON_STARTUP=true

# Number of times the API waits for the local database during development bootstrap.
DEV_BOOTSTRAP_RETRIES=30

# Delay in seconds between development bootstrap retries.
DEV_BOOTSTRAP_RETRY_SECONDS=1

# === Auth ===
# Auth.js secret. In production set a high-entropy value; local dev may use this value.
AUTH_SECRET=dev-auth-secret-change-in-production

# Auth.js URL. Must match APP_URL for local dev.
AUTH_URL=http://localhost:3000

# Local mock Google OIDC issuer used when GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET are blank.
AUTH_MOCK_GOOGLE_ISSUER=http://localhost:8000

# Optional server-side discovery URL for the mock Google provider. Empty uses AUTH_MOCK_GOOGLE_ISSUER.
AUTH_MOCK_GOOGLE_DISCOVERY_URL=

# Optional internal endpoint base emitted by mock Google discovery for token/userinfo/JWKS.
# Empty uses AUTH_MOCK_GOOGLE_ISSUER. Compose sets this to the API service URL.
AUTH_MOCK_GOOGLE_SERVER_BASE_URL=

# JWKS endpoint exposed by the web app for API-side Auth.js JWT validation.
AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks

# Issuer claim for Auth.js API JWTs. Must match AUTH_URL locally.
AUTH_JWT_ISSUER=http://localhost:3000

# Audience claim expected by the FastAPI backend.
AUTH_JWT_AUDIENCE=prompteer-api

# Optional RS256 private key PEM for Auth.js API JWTs. Empty uses a process-local dev key outside prod.
AUTH_JWT_PRIVATE_KEY=

# Key id exposed in the Auth.js JWKS document.
AUTH_JWT_KEY_ID=prompteer-dev-auth

# Google OAuth client id. Leave blank to use the mock Google OAuth provider.
GOOGLE_CLIENT_ID=

# Google OAuth client secret. Leave blank to use the mock Google OAuth provider.
GOOGLE_CLIENT_SECRET=

# Enables deterministic dev login routes and seed users. Defaults true in dev, false in prod.
AUTH_ALLOW_SEED_LOGIN=true

# Enables browser-visible Google auth mock affordances in local development.
NEXT_PUBLIC_USE_MOCK_GOOGLE=true

# === Observability ===
# Emit JSON logs when true. Defaults to false outside production.
LOG_JSON=false

# Optional Sentry DSN for backend errors. Empty disables Sentry.
SENTRY_DSN=

# Optional Sentry DSN for browser/server web errors. Empty disables Sentry.
NEXT_PUBLIC_SENTRY_DSN=

# Optional Sentry organization slug for web source map uploads. Empty skips uploads.
SENTRY_ORG=

# Optional Sentry project slug for web source map uploads. Empty skips uploads.
SENTRY_PROJECT=

# Optional Sentry auth token for source map uploads. Empty skips uploads.
SENTRY_AUTH_TOKEN=

# === External APIs (leave blank to use mocks) ===
# OpenAI API key. Empty selects the deterministic mock LLM client unless Anthropic is set.
OPENAI_API_KEY=

# OpenAI API base URL. Defaults to the official v1 API; useful for tests or proxies.
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI Chat Completions model used for real prompt runs.
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Anthropic API key. Empty selects the deterministic mock LLM client unless OpenAI is set.
ANTHROPIC_API_KEY=

# Anthropic API base URL. Defaults to the official v1 API; useful for tests or proxies.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Anthropic Messages model used for real prompt runs.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Anthropic API version header sent to the Messages API.
ANTHROPIC_VERSION=2023-06-01

# Stripe secret key. Empty selects the mock payments client.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Empty selects mock webhook signing.
STRIPE_WEBHOOK_SECRET=

# Twilio SendGrid API key. Empty selects the mock email client.
SENDGRID_API_KEY=

# Default sender used by real and mock email clients.
SENDGRID_FROM_EMAIL=no-reply@prompteer.dev

# Optional directory for captured mock SendGrid .eml files. Empty stores under ./.mock/email.
MOCK_MAILBOX_DIR=

# === Verification tooling ===
# Optional URL used by scripts/verify-ui.mjs. Defaults to the Docker Compose nginx origin.
PROMPTEER_WEB_URL=http://localhost/en

# Optional Playwright base URL. Defaults to the Docker Compose nginx origin.
PLAYWRIGHT_BASE_URL=http://localhost

# Docker Compose wait timeout in seconds for scripts/bootstrap.sh. Empty uses 300 seconds.
COMPOSE_WAIT_TIMEOUT=300

# Services that scripts/check-compose-health.sh requires to be running and healthy.
COMPOSE_HEALTH_SERVICES=postgres redis api worker web nginx

# === Feature flags ===
# Enables dev-only routes such as /api/v1/dev/mailbox and mock checkout completion.
ENABLE_DEV_ROUTES=true

# Enables LLM prompt runs and provider-compatible LLM mock endpoints.
FEATURE_LLM_ENABLED=true

# Enables billing checkout and provider-compatible Stripe mock endpoints.
FEATURE_PAYMENTS_ENABLED=true

# Enables email delivery and the provider-compatible SendGrid mock endpoint.
FEATURE_EMAIL_ENABLED=true
