{
  "name": "@prompteer/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "openapi-typescript ../../docs/api/openapi-v1.json -o src/api.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@prompteer/eslint-config": "workspace:*",
    "@prompteer/tsconfig": "workspace:*",
    "eslint": "^10.4.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
