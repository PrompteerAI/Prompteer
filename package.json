{
  "name": "prompteer",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "prepare": "if [ \"${HUSKY:-}\" = \"0\" ]; then exit 0; else sh scripts/install-hooks.sh; fi",
    "dev": "scripts/dev.sh",
    "dev:legacy": "scripts/dev-legacy.sh",
    "build": "turbo build",
    "build:legacy": "pnpm --filter @prompteer/web-legacy build",
    "lint": "turbo lint",
    "lint:legacy": "pnpm --filter @prompteer/web-legacy lint",
    "typecheck": "turbo typecheck",
    "typecheck:legacy": "pnpm --filter @prompteer/web-legacy typecheck",
    "test": "turbo test",
    "audit": "pnpm audit --audit-level moderate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:pre-commit": "pnpm lint-staged && uv run --project apps/api pre-commit run --hook-stage pre-commit",
    "source-headers": "node scripts/check-source-headers.mjs",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  }
}
